{
    "name": "whymeet-server",
    "displayName": "WhyMeet Server",
    "version": "0.0.1",
    "private": true,
    "type": "commonjs",
    "license": "UNLICENSED",
    "scripts": {
        "start": "node dist/src/index.js",
        "build": "tsc && tsc-alias",
        "dev": "npm run build && npm run start",
        "typecheck": "tsc --noEmit",
        "lint": "eslint ./src/",
        "lint:fix": "eslint ./src/ --fix",
        "format": "prettier --check 'src/**/*.{ts,tsx}'",
        "format:fix": "prettier --write 'src/**/*.{ts,tsx}'",
        "test": "jest --detectOpenHandles --passWithNoTests",
        "clean": "rm -rf dist node_modules package-lock.json",
        "ci": "npm run lint && npm run format && npm run typecheck && npm run test",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@whymeet/types": "file:../WhyMeet-Types/dist",
        "@prisma/client": "^6.8.2",
        "cors": "^2.8.5",
        "dotenv": "^16.5.0",
        "express": "^5.1.0",
        "helmet": "^8.1.0",
        "morgan": "^1.10.0",
        "ws": "^8.18.2",
        "zod": "^3.25.20"
    },
    "devDependencies": {
        "@eslint/js": "^9.27.0",
        "@types/cors": "^2.8.18",
        "@types/express": "^5.0.1",
        "@types/jest": "^29.5.14",
        "@types/morgan": "^1.9.9",
        "@types/ws": "^8.18.1",
        "eslint": "^9.27.0",
        "eslint-plugin-prettier": "^5.4.0",
        "globals": "^16.1.0",
        "jest": "^29.7.0",
        "prettier": "^3.5.3",
        "prisma": "^6.8.2",
        "ts-jest": "^29.3.4",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.1"
    },
    "engines": {
        "node": ">=22"
    }
}
