generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// ─── Auth & Users ───────────────────────────────────────────────────

model User {
    id           String   @id @default(cuid())
    email        String   @unique
    passwordHash String
    name         String
    age          Int
    avatar       String   @default("")
    city         String   @default("")
    verified     Boolean  @default(false)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    profile       Profile?
    intentions    UserIntention[]
    tags          UserTag[]
    sentMatches   Match[]          @relation("MatchSender")
    receivedMatches Match[]        @relation("MatchReceiver")
    messages      Message[]
    notifications Notification[]
    conversations ConversationParticipant[]

    @@map("users")
}

model Profile {
    id         String @id @default(cuid())
    userId     String @unique
    bio        String @default("")
    socialVibe String @default("chill")
    country    String @default("")
    region     String @default("")
    city       String @default("")

    // Stats (denormalized for performance)
    statConnections Int @default(0)
    statMatches     Int @default(0)
    statVibes       Int @default(0)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("profiles")
}

// ─── Intentions ─────────────────────────────────────────────────────

model Intention {
    id          String @id @default(cuid())
    category    String // dating, friendship, sports, music, nightlife, gaming, activities
    label       String
    description String @default("")

    tags  IntentionTag[]
    users UserIntention[]

    @@map("intentions")
}

model UserIntention {
    id          String @id @default(cuid())
    userId      String
    intentionId String

    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    intention Intention @relation(fields: [intentionId], references: [id], onDelete: Cascade)

    @@unique([userId, intentionId])
    @@map("user_intentions")
}

// ─── Tags ───────────────────────────────────────────────────────────

model Tag {
    id    String @id @default(cuid())
    label String @unique

    intentionTags IntentionTag[]
    userTags      UserTag[]

    @@map("tags")
}

model IntentionTag {
    id          String @id @default(cuid())
    intentionId String
    tagId       String

    intention Intention @relation(fields: [intentionId], references: [id], onDelete: Cascade)
    tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@unique([intentionId, tagId])
    @@map("intention_tags")
}

model UserTag {
    id     String @id @default(cuid())
    userId String
    tagId  String
    type   String // "interest" | "skill"

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@unique([userId, tagId, type])
    @@map("user_tags")
}

// ─── Matching ───────────────────────────────────────────────────────

model Match {
    id           String   @id @default(cuid())
    senderId     String
    receiverId   String
    category     String   // IntentionCategory
    matchContext String   @default("")
    mutual       Boolean  @default(false)
    matchedAt    DateTime @default(now())

    sender   User @relation("MatchSender", fields: [senderId], references: [id], onDelete: Cascade)
    receiver User @relation("MatchReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

    @@unique([senderId, receiverId, category])
    @@map("matches")
}

// ─── Conversations & Messages ───────────────────────────────────────

model Conversation {
    id                String   @id @default(cuid())
    intentionCategory String
    intentionLabel    String   @default("")
    createdAt         DateTime @default(now())

    participants ConversationParticipant[]
    messages     Message[]

    @@map("conversations")
}

model ConversationParticipant {
    id             String @id @default(cuid())
    conversationId String
    userId         String
    unreadCount    Int    @default(0)

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([conversationId, userId])
    @@map("conversation_participants")
}

model Message {
    id             String   @id @default(cuid())
    conversationId String
    senderId       String
    text           String
    timestamp      DateTime @default(now())

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

    @@index([conversationId, timestamp])
    @@map("messages")
}

// ─── Notifications ──────────────────────────────────────────────────

model Notification {
    id        String   @id @default(cuid())
    userId    String
    type      String   // match, message, like, system
    title     String
    body      String
    read      Boolean  @default(false)
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, read])
    @@map("notifications")
}
