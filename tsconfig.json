{
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"],
    "compilerOptions": {
        "composite": true,
        "target": "ES2024",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "baseUrl": "./",
        "paths": {
            "@/*": ["./src/*"]
        },
        "outDir": "./dist",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    }
}
