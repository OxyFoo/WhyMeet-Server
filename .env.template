#
# Server configuration
#
ENVIRONMENT=dev

#
# Domains & Ports
#
LISTEN_PORT_WS=4600
PUBLIC_APP_URL=http://127.0.0.1:4600

#
# Logs management
#
LOG_LEVEL=normal
# LOG_LEVEL=minimal|normal|all
LOG_PATH=./logs
LOG_KEEP_DAYS=30

#
# SSL configuration (optional, leave empty for no SSL)
#
SSL_PRIVATE_KEY_PATH=
SSL_CERTIFICATE_PATH=

#
# Database configuration (PostgreSQL)
#
DATABASE_URL=postgresql://whymeet:whymeet@localhost:5432/whymeet?schema=public

#
# PostgreSQL credentials (used by Docker Compose to configure PgBouncer)
#
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRESQL_USERNAME=whymeet
POSTGRESQL_PASSWORD=whymeet
POSTGRESQL_DATABASE=whymeet

#
# JWT configuration
#
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

#
# Tag Promotion batch job
# TAG_PROMOTION_ENABLED: set to false to disable the nightly promotion pass
# TAG_PROMOTION_WINDOW_HOUR_UTC: UTC hour at which the daily pass runs (0-23, default 2)
#
TAG_PROMOTION_ENABLED=true
TAG_PROMOTION_WINDOW_HOUR_UTC=2

#
# Encryption key for email validation tokens (min 16 chars)
#
CRYPT_KEY_MAIL=change-me-in-production-mail

#
# WebSocket token expiration (seconds)
#
WS_TOKEN_EXPIRES_SECONDS=60

#
# Mail token expiration (minutes)
#
MAIL_TOKEN_TTL_MINUTES=15

#
# SMTP configuration (optional, falls back to console logging if empty)
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@whymeet.app

#
# S3-compatible storage (avatar uploads)
#
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=whymeet-uploads
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me-secret
S3_REGION=us-east-1
S3_PUBLIC_URL=http://127.0.0.1:9000/whymeet-uploads
UPLOAD_MAX_SIZE=5242880

#
# Redis (optional — leave empty to disable caching, app degrades gracefully)
#
REDIS_URL=
REDIS_TTL_CANDIDATE_S=300
REDIS_TTL_SETUP_S=60

#
# Firebase (push notifications, optional)
# Stringified JSON of the service account key
#
FIREBASE_SERVICE_ACCOUNT=

#
# OAuth providers (optional)
#
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

#
# OpenAI API Key for GPT-based features (optional)
#
OPENAI_API_KEY=

#
# Apple IAP Promotional Offer signing (optional)
# Generate in App Store Connect > Users & Access > Keys > In-App Purchase
#
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY=
APP_BUNDLE_ID=com.whymeet.app

#
# Device integrity verification (optional — disabled by default)
# See docs/integrity-setup.md for full setup guide
#
INTEGRITY_CHECK_ENABLED=false
# Google Play Integrity — project number from Google Cloud Console
GOOGLE_CLOUD_PROJECT_NUMBER=
# Google Service Account key (JSON stringified) with Play Integrity API access
GOOGLE_SERVICE_ACCOUNT_KEY=
# Apple App Attest environment: "production" or "development"
APPLE_APP_ATTEST_ENVIRONMENT=production

#
# Admin Console HMAC (Generate with: openssl rand -hex 32)
# Shared secret with WhyMeet-Console for signing /admin/* requests.
#
ADMIN_API_SECRET=

#
# Mapbox Search Box + Static Images API (places autocomplete, mini-maps)
# https://docs.mapbox.com/api/search/search-box/
#
MAPBOX_ACCESS_TOKEN=
