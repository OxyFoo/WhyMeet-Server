generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// ─── Auth & Users ───────────────────────────────────────────────────

model User {
    id                     String    @id @default(cuid())
    email                  String    @unique
    name                   String    @default("")
    birthDate              DateTime?
    birthDateLastChangedAt DateTime?
    underageDeclared       Boolean   @default(false)
    gender                 String    @default("")
    city                   String    @default("")
    verified               Boolean   @default(false)
    banned                 Boolean   @default(false)
    suspended              Boolean   @default(false)
    suspendedAt            DateTime?
    deleted                Boolean   @default(false)
    deletedAt              DateTime?
    appealMessage          String?   @db.VarChar(500)
    appealRequestedAt      DateTime?
    preferredPeriod        String    @default("any")
    /// Synthetic account created by the admin stresstest tool. Excluded from
    /// real users' discovery (people + activities) and from dashboard stats.
    bot                    Boolean   @default(false)
    createdAt              DateTime  @default(now())
    updatedAt              DateTime  @updatedAt

    profile                Profile?
    settings               Settings?
    devices                Device[]
    photos                 ProfilePhoto[]
    tags                   UserTag[]
    sentMatches            Match[]                   @relation("MatchSender")
    receivedMatches        Match[]                   @relation("MatchReceiver")
    messages               Message[]
    notifications          Notification[]
    conversations          ConversationParticipant[]
    blockedUsers           Block[]                   @relation("Blocker")
    blockedBy              Block[]                   @relation("Blocked")
    sentReports            Report[]                  @relation("Reporter")
    receivedReports        Report[]                  @relation("Reported")
    ipLogs                 IpLog[]
    subscription           Subscription?
    premiumOverride        PremiumOverride?
    activeBoost            ActiveBoost?
    searchQuota            SearchQuota?
    swipeQuota             SwipeQuota?
    activityQuota          ActivityQuota?
    activityOpens          ActivityOpen[]
    hostedActivities       Activity[]                @relation("ActivityHost")
    activityParticipations ActivityParticipant[]
    activityReports        ActivityReport[]
    badges                 UserBadge[]
    auditLogs              AuditLog[]
    feedbacks              Feedback[]
    suspiciousActivity     SuspiciousActivity?

    @@index([bot])
    @@index([underageDeclared])
    @@map("users")
}

model Device {
    id                  String    @id @default(cuid())
    uuid                String    @unique
    sessionTokenHash    String
    mailTokenHash       String?
    status              String    @default("pending") // "pending" | "active"
    name                String    @default("")
    os                  String    @default("")
    pushToken           String?
    pushProvider        String? // "fcm"
    lastIp              String?
    createdAt           DateTime  @default(now())
    lastSeenAt          DateTime  @default(now())
    integrityVerifiedAt DateTime?

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

    ipLogs IpLog[]

    @@index([userId])
    @@map("devices")
}

model Profile {
    id         String @id @default(cuid())
    userId     String @unique
    bio        String @default("")
    socialVibe String @default("balanced")
    country    String @default("")
    region     String @default("")
    city       String @default("")
    latitude   Float?
    longitude  Float?

    // Stats (denormalized for performance)
    statConnections Int @default(0)
    statMatches     Int @default(0)
    statVibes       Int @default(0)

    // Intentions (static keys from @oxyfoo/whymeet-types IntentionKey)
    intentionKeys String[] @default([])

    // Category-level intentions: the user signaled interest in a whole category
    // without picking specific intentions inside it. Mutex with intentionKeys
    // at the category level (enforced server-side in update-profile).
    intentionCategoryKeys String[] @default([])

    // Spoken languages for remote matching
    spokenLanguages String[] @default(["fr"])

    // Trust & hosting stats (denormalized)
    trustScore           Int @default(0)
    completedHostedCount Int @default(0)
    cancelledHostedCount Int @default(0)

    // UI preference: last discovery view ("swipe" | "advanced"). Stored for stats + UX.
    preferredDiscoveryView String @default("swipe")

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("profiles")
}

model Settings {
    id       String @id @default(cuid())
    userId   String @unique
    language String @default("fr") // Language: "fr" | "en"
    theme    String @default("light") // Theme: "light" | "dark"

    // People discovery preferences (who I want to see)
    peopleAgeMin      Int      @default(18)
    peopleAgeMax      Int      @default(99)
    peopleGenders     String[] @default(["male", "female", "non_binary", "other", "prefer_not_to_say"])
    peopleMaxDistance Int      @default(50)
    peopleRemoteMode  Boolean  @default(false)
    peopleVerified    Boolean  @default(false)
    peoplePhotosOnly  Boolean  @default(false)
    peopleLanguages   String[] @default([])

    // Activity discovery preferences (which activities to see, filtering on host profile)
    activityGenders     String[] @default(["male", "female", "non_binary", "other", "prefer_not_to_say"])
    activityMaxDistance Int      @default(50)
    activityRemoteMode  Boolean  @default(false)
    activityVerified    Boolean  @default(false)
    activityLanguages   String[] @default([])

    // Visibility preferences (who can see me)
    syncVisibility        Boolean  @default(true)
    visibilityAgeMin      Int      @default(18)
    visibilityAgeMax      Int      @default(99)
    visibilityGenders     String[] @default(["male", "female", "non_binary", "other", "prefer_not_to_say"])
    visibilityMaxDistance Int      @default(50)
    visibilityRemoteMode  Boolean  @default(false)

    // Notification preferences
    notifNewMatch            Boolean @default(true)
    notifLikes               Boolean @default(true)
    notifMessages            Boolean @default(true)
    notifNearbyPeople        Boolean @default(true)
    notifActivityReminder24h Boolean @default(true)
    notifActivityReminder1h  Boolean @default(true)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("settings")
}

// ─── Tags ───────────────────────────────────────────────────────────

model ProfilePhoto {
    id          String   @id @default(cuid())
    userId      String
    key         String // S3 object key
    keyBlurred  String // S3 object key for the pre-blurred preview variant
    description String   @default("")
    position    Int      @default(0)
    createdAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("profile_photos")
}

model Tag {
    id        String   @id @default(cuid())
    label     String   @unique
    embedding Float[]  @default([])
    // Canonical domain key (one of InterestCategoryKey from @oxyfoo/whymeet-types).
    // Populated lazily via embedding similarity; null when unknown or embeddings disabled.
    domainKey String?
    // Timestamp when this canonical tag was created (seed time or promotion job time).
    createdAt DateTime @default(now())

    userTags UserTag[]
    aliases  TagAlias[]

    @@index([domainKey])
    @@map("tags")
}

model TagAlias {
    id        String   @id @default(cuid())
    alias     String   @unique
    tagId     String
    // Timestamp when this alias was created (seed time or promotion job time).
    createdAt DateTime @default(now())

    tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@index([tagId])
    @@map("tag_aliases")
}

model UserTag {
    id         String   @id @default(cuid())
    userId     String
    // Raw user-typed (sanitised) label. This is the source of truth for what
    // is displayed on the profile and what scoring matches between users.
    label      String
    // Lowercased label, used for case-insensitive equality / grouping.
    labelLower String
    // Robust normalized label (accents removed, unicode NFD, spaces/hyphens/punctuation normalized, lowercase).
    // Used for multi-level clustering in promotion job to catch typos/variants.
    // Prevents duplicate-variant tags on same user.
    labelNorm  String
    // Optional link to a canonical Tag. Populated when the label resolves to
    // an existing canonical via exact / alias match at save time, or by the
    // tag-promotion job that retroactively links clusters.
    tagId      String?
    type       String // "interest" | "skill"
    // Provenance marker — how this tag was added to the user profile.
    // Values: "free" (typed), "popular" (popular-tags chip),
    // "refine:<step_key>" (chosen from a refine wizard step), or null (legacy).
    source     String?
    // Timestamp when this tag was added to the user profile.
    createdAt  DateTime @default(now())
    // Timestamp when this tag was last updated (provenance or label change).
    updatedAt  DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    tag  Tag? @relation(fields: [tagId], references: [id], onDelete: SetNull)

    @@unique([userId, type, labelNorm])
    @@index([tagId])
    @@index([userId, source])
    @@index([labelLower])
    @@index([labelNorm])
    @@index([type, labelNorm])
    @@map("user_tags")
}

// ─── Matching ───────────────────────────────────────────────────────

model Match {
    id           String   @id @default(cuid())
    senderId     String
    receiverId   String
    category     String // "like" | "skip"
    matchContext String   @default("")
    categoryKey  String?
    intentionKey String?
    mutual       Boolean  @default(false)
    matchedAt    DateTime @default(now())

    sender            User                      @relation("MatchSender", fields: [senderId], references: [id], onDelete: Cascade)
    receiver          User                      @relation("MatchReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
    intentionCategory IntentionCategoryCatalog? @relation(fields: [categoryKey], references: [key], onDelete: SetNull, onUpdate: Cascade)
    intention         IntentionCatalog?         @relation(fields: [intentionKey], references: [key], onDelete: SetNull, onUpdate: Cascade)

    @@unique([senderId, receiverId, category])
    @@index([receiverId])
    @@map("matches")
}

// ─── Intention Catalog ─────────────────────────────────────────

model IntentionCategoryCatalog {
    key String @id

    intentions IntentionCatalog[]
    matches    Match[]

    @@map("intention_categories")
}

model IntentionCatalog {
    key         String @id
    categoryKey String

    category IntentionCategoryCatalog @relation(fields: [categoryKey], references: [key], onDelete: Cascade, onUpdate: Cascade)
    matches  Match[]

    @@index([categoryKey])
    @@map("intentions")
}

// ─── Conversations & Messages ───────────────────────────────────────

model Conversation {
    id            String   @id @default(cuid())
    isGroup       Boolean  @default(false)
    createdAt     DateTime @default(now())
    lastMessageAt DateTime @default(now())

    participants ConversationParticipant[]
    messages     Message[]
    activity     Activity?

    @@index([lastMessageAt(sort: Desc), id(sort: Desc)])
    @@map("conversations")
}

model ConversationParticipant {
    id             String @id @default(cuid())
    conversationId String
    userId         String
    unreadCount    Int    @default(0)

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([conversationId, userId])
    @@index([userId])
    @@map("conversation_participants")
}

model Message {
    id             String   @id @default(cuid())
    conversationId String
    senderId       String
    text           String
    type           String   @default("text") // text | user_joined | user_left | shared_activity
    read           Boolean  @default(false)
    timestamp      DateTime @default(now())
    activityId     String?

    conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
    sharedActivity Activity?    @relation("MessageSharedActivity", fields: [activityId], references: [id], onDelete: SetNull)

    @@index([conversationId, timestamp])
    @@index([senderId])
    @@index([activityId])
    @@map("messages")
}

// ─── Notifications ──────────────────────────────────────────────────

model Notification {
    id         String   @id @default(cuid())
    userId     String
    type       String // match, message, like, system, activity_reminder
    title      String
    body       String
    read       Boolean  @default(false)
    activityId String?
    createdAt  DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, read])
    @@map("notifications")
}

// ─── Moderation ─────────────────────────────────────────────────────

model Block {
    id        String   @id @default(cuid())
    blockerId String
    blockedId String
    createdAt DateTime @default(now())

    blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
    blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

    @@unique([blockerId, blockedId])
    @@index([blockedId])
    @@map("blocks")
}

model Report {
    id           String   @id @default(cuid())
    reporterId   String
    reportedId   String
    reason       String // "spam" | "fake_profile" | "inappropriate" | "hate_speech" | "underage" | "other"
    sourceType   String   @default("profile") // "profile" | "conversation" | "activity"
    sourceId     String?
    message      String   @default("") @db.VarChar(500)
    status       String   @default("pending") // "pending" | "reviewing" | "resolved_action_taken" | "resolved_no_action"
    isLegitimate Boolean  @default(true)
    createdAt    DateTime @default(now())

    reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
    reported User @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)

    @@unique([reporterId, reportedId])
    @@index([reportedId])
    @@index([status])
    @@map("reports")
}

model IpLog {
    id        String   @id @default(cuid())
    ip        String
    userId    String
    deviceId  String
    createdAt DateTime @default(now())

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

    @@index([ip])
    @@index([userId])
    @@map("ip_logs")
}

/// Bot / suspicious-activity flagging. One row per flagged user, recomputed
/// by the periodic suspiciousActivityService scan. `signals` is a JSON map
/// of triggered signal keys to numeric scores.
model SuspiciousActivity {
    id                    String    @id @default(cuid())
    userId                String    @unique
    score                 Int // 0..100, weighted sum of triggered signals
    signals               Json // { [signalKey: string]: number }
    firstDetectedAt       DateTime  @default(now())
    lastDetectedAt        DateTime  @default(now())
    acknowledgedAt        DateTime?
    acknowledgedByAdminId String? // AdminUser.id (Console scope)
    resolvedAt            DateTime?
    resolvedByAdminId     String? // AdminUser.id (Console scope)
    notes                 String?   @db.VarChar(1000)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([score])
    @@index([lastDetectedAt])
    @@index([resolvedAt])
    @@map("suspicious_activities")
}

// ─── Audit Logs ───────────────────────────────────────────────────

model AuditLog {
    id               String   @id @default(cuid())
    userId           String?
    action           String
    targetActivityId String?
    metadata         Json?
    ip               String?
    createdAt        DateTime @default(now())

    user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
    activity Activity? @relation(fields: [targetActivityId], references: [id], onDelete: SetNull)

    @@index([userId, action])
    @@index([targetActivityId, createdAt])
    @@index([createdAt])
    @@map("audit_logs")
}

// ─── External API usage tracking ──────────────────────────────

model ApiUsageEvent {
    id        String   @id @default(cuid())
    provider  String // "mapbox", "openai", ...
    endpoint  String // "geocoding/suggest", "chat/completions", ...
    status    Int // HTTP status code (0 if network error)
    latencyMs Int
    userId    String?
    errorCode String?
    metadata  Json?
    createdAt DateTime @default(now())

    @@index([provider, createdAt])
    @@index([provider, status, createdAt])
    @@map("api_usage_events")
}

// ─── Server-wide feature flags ────────────────────────────────

model FeatureFlag {
    key       String   @id
    enabled   Boolean
    updatedAt DateTime @updatedAt

    @@map("feature_flags")
}

/// Global numeric settings for runtime-tunable app behavior.
/// Keys are human-readable strings (for example: "counter.swipe.daily.free").
model AppConfig {
    key       String   @id
    valueInt  Int
    updatedAt DateTime @updatedAt

    @@map("app_config")
}

// ─── Email tracking ───────────────────────────────────────────────

/// Every email dispatched by the system (Server or Console) is logged here.
/// Powers the `/emails` dashboard in the Console.
model EmailLog {
    id              String   @id @default(cuid())
    type            String // EmailTypeKey from @oxyfoo/whymeet-types
    recipientEmail  String
    recipientUserId String?
    subject         String
    status          String // "sent" | "failed" | "skipped"
    errorMessage    String?
    metadata        Json?
    sentBy          String // "server" | "console"
    actorAdminId    String? // AdminUser.id (Console scope only)
    createdAt       DateTime @default(now())

    @@index([type, createdAt])
    @@index([recipientEmail])
    @@index([status, createdAt])
    @@index([createdAt])
    @@map("email_logs")
}

/// Per-type override allowing admins to disable an automatic email type
/// without changing code. Only types where `toggleable: true` in the
/// `EMAIL_TYPES` catalog respect this flag. Missing row = enabled.
model EmailAutoConfig {
    type      String   @id // EmailTypeKey
    enabled   Boolean  @default(true)
    updatedAt DateTime @updatedAt
    updatedBy String? // AdminUser.id

    @@map("email_auto_config")
}

// ─── Subscription & Monetization ────────────────────────────────────

model Subscription {
    id                    String    @id @default(cuid())
    userId                String    @unique
    plan                  String // "monthly" | "semi_annual" | "annual"
    status                String    @default("active") // "active" | "expired" | "cancelled" | "grace_period"
    platform              String // "ios" | "android"
    productId             String
    originalTransactionId String    @default("")
    expiresAt             DateTime
    cancelledAt           DateTime?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("subscriptions")
}

model PremiumOverride {
    id               String   @id @default(cuid())
    userId           String   @unique
    forcedPremium    Boolean
    reason           String   @db.VarChar(500)
    expiresAt        DateTime
    updatedByAdminId String?
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([expiresAt])
    @@index([forcedPremium, expiresAt])
    @@map("premium_overrides")
}

model ActiveBoost {
    id        String   @id @default(cuid())
    userId    String   @unique
    expiresAt DateTime
    source    String // "purchase" | "subscription"
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("active_boosts")
}

// ─── Daily Quotas ─────────────────────────────────────────────────────
// All three quotas share the same shape: { remaining, resetAt }.
// `resetAt` is the next reset instant (midnight UTC); when now >= resetAt the
// quota refills back to its configured daily limit (see usageLimitsService).

model SearchQuota {
    id        String   @id @default(cuid())
    userId    String   @unique
    remaining Int      @default(5)
    resetAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("search_quotas")
}

model SwipeQuota {
    id        String   @id @default(cuid())
    userId    String   @unique
    remaining Int      @default(20)
    resetAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("swipe_quotas")
}

model ActivityQuota {
    id        String   @id @default(cuid())
    userId    String   @unique
    remaining Int      @default(3)
    resetAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("activity_quotas")
}

// Tracks the first daily open of an activity per user to make the
// activity-quota debit idempotent across refetches of the same activity.
model ActivityOpen {
    id         String   @id @default(cuid())
    userId     String
    activityId String
    day        DateTime @db.Date
    createdAt  DateTime @default(now())

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@unique([userId, activityId, day])
    @@index([userId, day])
    @@map("activity_opens")
}

// ─── Activities ─────────────────────────────────────────────────────

model Activity {
    id                    String    @id @default(cuid())
    hostId                String
    title                 String
    description           String    @default("")
    category              String // InterestCategoryKey
    dateTime              DateTime?
    durationMinutes       Int?
    locationName          String
    latitude              Float
    longitude             Float
    maxParticipants       Int?
    isCancelled           Boolean   @default(false)
    isArchived            Boolean   @default(false)
    isCompleted           Boolean   @default(false)
    hostConfirmedAt       DateTime?
    hostReportedAttendees Int?
    targetGenders         String[]  @default(["male", "female", "non_binary", "other", "prefer_not_to_say"])
    targetAgeRange        Int[]     @default([18, 80])
    conversationId        String?   @unique
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    host             User                     @relation("ActivityHost", fields: [hostId], references: [id], onDelete: Cascade)
    conversation     Conversation?            @relation(fields: [conversationId], references: [id])
    participants     ActivityParticipant[]
    photos           ActivityPhoto[]
    reports          ActivityReport[]
    scheduledNotifs  ActivityScheduledNotif[]
    opens            ActivityOpen[]
    auditLogs        AuditLog[]
    sharedInMessages Message[]                @relation("MessageSharedActivity")

    @@index([hostId])
    @@index([category])
    @@index([dateTime])
    @@map("activities")
}

model ActivityParticipant {
    id                  String   @id @default(cuid())
    activityId          String
    userId              String
    joinedAt            DateTime @default(now())
    confirmedAttendance Boolean?

    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([activityId, userId])
    @@index([userId])
    @@map("activity_participants")
}

model ActivityPhoto {
    id         String   @id @default(cuid())
    activityId String
    key        String // S3 object key
    keyBlurred String // S3 object key for the pre-blurred preview variant
    position   Int      @default(0)
    createdAt  DateTime @default(now())

    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@index([activityId])
    @@map("activity_photos")
}

model ActivityReport {
    id           String   @id @default(cuid())
    reporterId   String
    activityId   String
    reason       String // ReportReason
    message      String   @default("") @db.VarChar(500)
    status       String   @default("pending")
    isLegitimate Boolean  @default(true)
    createdAt    DateTime @default(now())

    reporter User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@unique([reporterId, activityId])
    @@index([activityId])
    @@map("activity_reports")
}

model ActivityScheduledNotif {
    id          String    @id @default(cuid())
    activityId  String
    type        String // "24h" | "1h" | "post_event"
    scheduledAt DateTime
    sent        Boolean   @default(false)
    sentAt      DateTime?

    activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

    @@unique([activityId, type])
    @@index([scheduledAt, sent])
    @@map("activity_scheduled_notifs")
}

// ─── Badges ─────────────────────────────────────────────────────────

/// Code-owned badge catalog. src/reference/badges.ts is the source of truth and may overwrite existing rows.
model BadgeDefinition {
    key                 String  @id
    emoji               String
    category            String // verification | seniority | hosting | participation
    threshold           Int?
    displayOrder        Int
    rewardType          String? // null | promotional_offer
    rewardOfferIdApple  String?
    rewardOfferIdGoogle String?
    rewardDescription   String?

    userBadges UserBadge[]

    @@map("badge_definitions")
}

model UserBadge {
    id              String    @id @default(cuid())
    userId          String
    badgeKey        String
    progress        Int       @default(0)
    earned          Boolean   @default(false)
    earnedAt        DateTime?
    rewardPendingAt DateTime?
    rewardClaimedAt DateTime?

    user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    definition BadgeDefinition @relation(fields: [badgeKey], references: [key])

    @@unique([userId, badgeKey])
    @@index([userId, earned])
    @@map("user_badges")
}

model Feedback {
    id        String   @id @default(cuid())
    userId    String?
    type      String // "bug" | "suggestion" | "other"
    message   String   @db.VarChar(1000)
    createdAt DateTime @default(now())

    user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([userId])
    @@index([type])
    @@map("feedbacks")
}

// Anonymous client-side analytics event (mobile app usage tracking).
// `deviceId` is the server-side cuid of the Device row (not the client uuid),
// so events stay anonymous from the outside while still allowing joins for
// derived stats (e.g. "% of devices whose user has a complete profile").
model AnalyticsEvent {
    id         String   @id @default(cuid())
    name       String
    deviceId   String
    ts         DateTime
    platform   String
    appVersion String
    props      Json?
    createdAt  DateTime @default(now())

    @@index([name, ts])
    @@index([ts])
    @@index([deviceId, ts])
    @@map("analytics_events")
}

// Pre-aggregated daily counters consumed by the admin dashboard.
// `dimension` is "" for the total or a "key=value" string (e.g. "platform=ios").
// Kept non-null so the (date,name,dimension) unique constraint works in Postgres.
model AnalyticsDailyMetric {
    id            String   @id @default(cuid())
    date          DateTime @db.Date
    name          String
    dimension     String   @default("")
    count         Int      @default(0)
    uniqueDevices Int      @default(0)
    updatedAt     DateTime @updatedAt

    @@unique([date, name, dimension])
    @@index([name, date])
    @@map("analytics_daily_metrics")
}
