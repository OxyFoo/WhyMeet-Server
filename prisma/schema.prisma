generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// ─── Auth & Users ───────────────────────────────────────────────────

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String   @default("")
    age       Int      @default(0)
    avatar    String   @default("")
    city      String   @default("")
    verified  Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    profile         Profile?
    devices         Device[]
    tags            UserTag[]
    sentMatches     Match[]                   @relation("MatchSender")
    receivedMatches Match[]                   @relation("MatchReceiver")
    messages        Message[]
    notifications   Notification[]
    conversations   ConversationParticipant[]

    @@map("users")
}

model Device {
    id               String   @id @default(cuid())
    uuid             String   @unique
    sessionTokenHash String
    mailTokenHash    String?
    status           String   @default("pending") // "pending" | "active"
    name             String   @default("")
    os               String   @default("")
    createdAt        DateTime @default(now())
    lastSeenAt       DateTime @default(now())

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("devices")
}

model Profile {
    id         String @id @default(cuid())
    userId     String @unique
    bio        String @default("")
    socialVibe String @default("chill")
    country    String @default("")
    region     String @default("")
    city       String @default("")

    // Stats (denormalized for performance)
    statConnections Int @default(0)
    statMatches     Int @default(0)
    statVibes       Int @default(0)

    // Intentions (static keys from @whymeet/types IntentionKey)
    intentions String[] @default([])

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("profiles")
}

// ─── Tags ───────────────────────────────────────────────────────────

model Tag {
    id    String @id @default(cuid())
    label String @unique

    userTags UserTag[]

    @@map("tags")
}

model UserTag {
    id     String @id @default(cuid())
    userId String
    tagId  String
    type   String // "interest" | "skill"

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@unique([userId, tagId, type])
    @@index([tagId])
    @@map("user_tags")
}

// ─── Matching ───────────────────────────────────────────────────────

model Match {
    id           String   @id @default(cuid())
    senderId     String
    receiverId   String
    category     String // IntentionKey
    matchContext String   @default("")
    mutual       Boolean  @default(false)
    matchedAt    DateTime @default(now())

    sender   User @relation("MatchSender", fields: [senderId], references: [id], onDelete: Cascade)
    receiver User @relation("MatchReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

    @@unique([senderId, receiverId, category])
    @@index([receiverId])
    @@map("matches")
}

// ─── Conversations & Messages ───────────────────────────────────────

model Conversation {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())

    participants ConversationParticipant[]
    messages     Message[]

    @@map("conversations")
}

model ConversationParticipant {
    id             String @id @default(cuid())
    conversationId String
    userId         String
    unreadCount    Int    @default(0)

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([conversationId, userId])
    @@index([userId])
    @@map("conversation_participants")
}

model Message {
    id             String   @id @default(cuid())
    conversationId String
    senderId       String
    text           String
    timestamp      DateTime @default(now())

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

    @@index([conversationId, timestamp])
    @@index([senderId])
    @@map("messages")
}

// ─── Notifications ──────────────────────────────────────────────────

model Notification {
    id        String   @id @default(cuid())
    userId    String
    type      String // match, message, like, system
    title     String
    body      String
    read      Boolean  @default(false)
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, read])
    @@map("notifications")
}
