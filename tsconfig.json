{
    "include": ["src/**/*", "src/**/*.json"],
    "exclude": ["node_modules", "dist"],
    "compilerOptions": {
        "composite": true,
        "target": "ES2024",
        "module": "CommonJS",
        "moduleResolution": "Bundler",
        "rootDir": "./src",
        "paths": {
            "@/*": ["./src/*"]
        },
        "outDir": "./dist",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "types": ["jest", "node"]
    }
}
