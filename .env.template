#
# Server configuration
#
ENVIRONMENT=dev
# ENVIRONMENT=prod

#
# Domains & Ports
#
LISTEN_PORT_WS=4600
DOMAIN=localhost

#
# Logs management
#
LOG_LEVEL=normal
# LOG_LEVEL=minimal|normal|all
LOG_PATH=./logs
LOG_KEEP_DAYS=30

#
# SSL configuration (optional, leave empty for no SSL)
#
SSL_PRIVATE_KEY_PATH=
SSL_CERTIFICATE_PATH=

#
# Database configuration (PostgreSQL)
#
DATABASE_URL=postgresql://whymeet:whymeet@localhost:5432/whymeet?schema=public

#
# JWT configuration
#
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
