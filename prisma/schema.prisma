generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// ─── Auth & Users ───────────────────────────────────────────────────

model User {
    id              String    @id @default(cuid())
    email           String    @unique
    name            String    @default("")
    birthDate       DateTime?
    gender          String    @default("")
    city            String    @default("")
    verified        Boolean   @default(false)
    banned          Boolean   @default(false)
    preferredPeriod String    @default("any")
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    profile         Profile?
    settings        Settings?
    devices         Device[]
    photos          ProfilePhoto[]
    tags            UserTag[]
    sentMatches     Match[]                   @relation("MatchSender")
    receivedMatches Match[]                   @relation("MatchReceiver")
    messages        Message[]
    notifications   Notification[]
    conversations   ConversationParticipant[]
    blockedUsers    Block[]                   @relation("Blocker")
    blockedBy       Block[]                   @relation("Blocked")
    sentReports     Report[]                  @relation("Reporter")
    receivedReports Report[]                  @relation("Reported")
    subscription    Subscription?
    activeBoost     ActiveBoost?
    tokenBalance    TokenBalance?
    swipeQuota      SwipeQuota?

    @@map("users")
}

model Device {
    id               String   @id @default(cuid())
    uuid             String   @unique
    sessionTokenHash String
    mailTokenHash    String?
    status           String   @default("pending") // "pending" | "active"
    name             String   @default("")
    os               String   @default("")
    pushToken        String?
    pushProvider     String? // "fcm"
    createdAt        DateTime @default(now())
    lastSeenAt       DateTime @default(now())

    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("devices")
}

model Profile {
    id         String @id @default(cuid())
    userId     String @unique
    bio        String @default("")
    socialVibe String @default("balanced")
    country    String @default("")
    region     String @default("")
    city       String @default("")
    latitude   Float?
    longitude  Float?

    // Stats (denormalized for performance)
    statConnections Int @default(0)
    statMatches     Int @default(0)
    statVibes       Int @default(0)

    // Intentions (static keys from @whymeet/types IntentionKey)
    intentions String[] @default([])

    // Spoken languages for remote matching
    spokenLanguages String[] @default(["fr"])

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("profiles")
}

model Settings {
    id       String @id @default(cuid())
    userId   String @unique
    language String @default("fr") // Language: "fr" | "en"
    theme    String @default("light") // Theme: "light" | "dark"

    // Discovery preferences (who I want to see)
    discoveryAgeMin      Int      @default(18)
    discoveryAgeMax      Int      @default(99)
    discoveryGenders     String[] @default(["male", "female", "non_binary", "other", "prefer_not_to_say"])
    discoveryIntentions  String[] @default([])
    discoveryMaxDistance Int      @default(50)
    discoveryRemoteMode  Boolean  @default(false)
    discoveryVerified    Boolean  @default(false)
    discoveryPhotosOnly  Boolean  @default(false)

    // Visibility preferences (who can see me)
    syncVisibility        Boolean  @default(true)
    visibilityAgeMin      Int      @default(18)
    visibilityAgeMax      Int      @default(99)
    visibilityGenders     String[] @default(["male", "female", "non_binary", "other", "prefer_not_to_say"])
    visibilityIntentions  String[] @default([])
    visibilityMaxDistance Int      @default(50)
    visibilityRemoteMode  Boolean  @default(false)

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("settings")
}

// ─── Tags ───────────────────────────────────────────────────────────

model ProfilePhoto {
    id          String   @id @default(cuid())
    userId      String
    key         String // S3 object key
    description String   @default("")
    position    Int      @default(0)
    createdAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@map("profile_photos")
}

model Tag {
    id        String  @id @default(cuid())
    label     String  @unique
    embedding Float[] @default([])

    userTags UserTag[]
    aliases  TagAlias[]

    @@map("tags")
}

model TagAlias {
    id    String @id @default(cuid())
    alias String @unique
    tagId String

    tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@index([tagId])
    @@map("tag_aliases")
}

model UserTag {
    id     String @id @default(cuid())
    userId String
    tagId  String
    type   String // "interest" | "skill"

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@unique([userId, tagId, type])
    @@index([tagId])
    @@map("user_tags")
}

// ─── Matching ───────────────────────────────────────────────────────

model Match {
    id           String   @id @default(cuid())
    senderId     String
    receiverId   String
    category     String // IntentionKey
    matchContext String   @default("")
    mutual       Boolean  @default(false)
    matchedAt    DateTime @default(now())

    sender   User @relation("MatchSender", fields: [senderId], references: [id], onDelete: Cascade)
    receiver User @relation("MatchReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

    @@unique([senderId, receiverId, category])
    @@index([receiverId])
    @@map("matches")
}

// ─── Conversations & Messages ───────────────────────────────────────

model Conversation {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now())

    participants ConversationParticipant[]
    messages     Message[]

    @@map("conversations")
}

model ConversationParticipant {
    id             String @id @default(cuid())
    conversationId String
    userId         String
    unreadCount    Int    @default(0)

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([conversationId, userId])
    @@index([userId])
    @@map("conversation_participants")
}

model Message {
    id             String   @id @default(cuid())
    conversationId String
    senderId       String
    text           String
    timestamp      DateTime @default(now())

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
    sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

    @@index([conversationId, timestamp])
    @@index([senderId])
    @@map("messages")
}

// ─── Notifications ──────────────────────────────────────────────────

model Notification {
    id        String   @id @default(cuid())
    userId    String
    type      String // match, message, like, system
    title     String
    body      String
    read      Boolean  @default(false)
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, read])
    @@map("notifications")
}

// ─── Moderation ─────────────────────────────────────────────────────

model Block {
    id        String   @id @default(cuid())
    blockerId String
    blockedId String
    createdAt DateTime @default(now())

    blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
    blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

    @@unique([blockerId, blockedId])
    @@index([blockedId])
    @@map("blocks")
}

model Report {
    id         String   @id @default(cuid())
    reporterId String
    reportedId String
    reason     String // "inappropriate" | "spam" | "harassment" | "fake" | "other"
    details    String   @default("")
    status     String   @default("pending") // "pending" | "reviewed" | "resolved"
    createdAt  DateTime @default(now())

    reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
    reported User @relation("Reported", fields: [reportedId], references: [id], onDelete: Cascade)

    @@index([reportedId])
    @@index([status])
    @@map("reports")
}

// ─── Subscription & Monetization ────────────────────────────────────

model Subscription {
    id                    String   @id @default(cuid())
    userId                String   @unique
    plan                  String // "monthly" | "semi_annual" | "annual"
    status                String   @default("active") // "active" | "expired" | "cancelled" | "grace_period"
    platform              String // "ios" | "android"
    productId             String
    originalTransactionId String   @default("")
    expiresAt             DateTime
    createdAt             DateTime @default(now())
    updatedAt             DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("subscriptions")
}

model ActiveBoost {
    id        String   @id @default(cuid())
    userId    String   @unique
    expiresAt DateTime
    source    String // "purchase" | "subscription"
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("active_boosts")
}

model TokenBalance {
    id           String   @id @default(cuid())
    userId       String   @unique
    tokens       Int      @default(5)
    lastRefillAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("token_balances")
}

model SwipeQuota {
    id         String   @id @default(cuid())
    userId     String   @unique
    swipesUsed Int      @default(0)
    resetAt    DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("swipe_quotas")
}
